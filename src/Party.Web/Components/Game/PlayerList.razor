@* Who's in the room. Shared by every game: the connection dot, the host star, watching/sitting
   out, and the host's "sit out" control are the same wherever you are. Anything a game wants to
   say against a name arrives through Badges, so this never learns about either game. *@

<div class="player-list">
    @foreach (var p in Seats)
    {
        <div class="player @(p.IsConnected ? "" : "away") @(p.Id == MyId ? "me" : "")">
            <span class="dot @(p.IsConnected ? "on" : "off")" title="@(p.IsConnected ? "connected" : "away")"></span>
            <span class="player-name">@p.Name</span>
            @if (p.IsHost)
            {
                <span class="badge" title="Host">★</span>
            }
            @if (p.IsBenched)
            {
                <span class="badge soft" title="Sitting out while away; back in when they reconnect">sitting out</span>
            }
            else if (p.IsSpectator)
            {
                <span class="badge soft" title="Joins next game">watching</span>
            }
            else if (HasHostPowers && !p.IsConnected && p.Id != MyId)
            {
                <button class="btn tiny" title="Sit them out until they reconnect, instead of working around them every round"
                        @onclick="() => OnBench.InvokeAsync(p.Id)">sit out</button>
            }
            @Badges?.Invoke(p)
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public required IReadOnlyList<RosterEntry> Seats { get; set; }

    [Parameter, EditorRequired] public required Guid MyId { get; set; }

    [Parameter, EditorRequired] public required bool HasHostPowers { get; set; }

    /// <summary>Sit an away player out — the host's one roster power, and the same in every game.</summary>
    [Parameter] public EventCallback<Guid> OnBench { get; set; }

    /// <summary>Whatever this game wants to show against a name.</summary>
    [Parameter] public RenderFragment<RosterEntry>? Badges { get; set; }
}
