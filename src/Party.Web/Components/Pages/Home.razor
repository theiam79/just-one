@page "/"
@inject RoomManager Rooms
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="home">
    <h1 class="logo">Party <span class="accent">Games</span></h1>
    <p class="tagline">Play together while you're on a call.</p>

    <div class="home-card">
        <label for="name">Your name</label>
        <input id="name" maxlength="@MaxNameLength" placeholder="e.g. Alex" @bind="_name" @bind:event="oninput" />

        @if (_error is not null)
        {
            <div class="banner error">@_error</div>
        }

        <div class="game-picker">
            @foreach (var game in GameInfo.All)
            {
                <button class="game-choice" @onclick="() => CreateRoom(game.Type)">
                    <span class="game-name">@game.Name</span>
                    <span class="game-tagline">@game.Tagline</span>
                    <span class="game-blurb">@game.Blurb</span>
                    <span class="btn primary">Create a room</span>
                </button>
            }
        </div>

        <div class="divider"><span>or join a friend's room</span></div>

        @* No game to pick here on purpose: a code already knows which game it is. *@
        <form class="join-row" @onsubmit="JoinRoom">
            <input class="code-input" maxlength="@RoomCode.Length" placeholder="CODE" @bind="_code" @bind:event="oninput" />
            <button class="btn" type="submit">Join</button>
        </form>
    </div>

    <p class="hint">Rooms are temporary — nothing is saved once everyone leaves.</p>
</div>

@code {
    // Any game's room may be created from here, so cap at the strictest.
    private static readonly int MaxNameLength =
        Math.Min(GameRoom.MaxNameLength, Party.Flip7.Flip7Room.MaxNameLength);

    private string _name = "";
    private string _code = "";
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _name = await JS.InvokeAsync<string>("party.getName");
        StateHasChanged();
    }

    private async Task CreateRoom(GameType game)
    {
        if (!await ValidateName())
        {
            return;
        }

        var handle = Rooms.CreateRoom(game);
        Nav.NavigateTo($"/room/{handle.Code}");
    }

    private async Task JoinRoom()
    {
        if (!await ValidateName())
        {
            return;
        }

        if (!Rooms.TryGetRoom(_code, out var handle))
        {
            _error = "No room with that code — check it with your host.";
            return;
        }

        Nav.NavigateTo($"/room/{handle.Code}");
    }

    private async Task<bool> ValidateName()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Enter a name first.";
            return false;
        }

        _error = null;
        await JS.InvokeVoidAsync("party.setName", _name.Trim());
        return true;
    }
}
