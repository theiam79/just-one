@using Party.Flip7
@inject IJSRuntime JS

<Confetti Active="@(_prefRead && _confetti && Celebrate)" />

<div class="phase-card">
    @if (View.Phase is Flip7Phase.GameOver)
    {
        <h2>@Winner!.Name wins on @Winner.Total</h2>
    }
    else if (View.Flip7PlayerId is { } id)
    {
        <h2>@(Name(id)) hit a Flip 7 — round over</h2>
        <p class="hint">Seven different numbers, +@Flip7Rules.Flip7Bonus, and everyone else banks what they had.</p>
    }
    else
    {
        <h2>Round @View.RoundNumber over</h2>
    }

    <div class="f7standings">
        @foreach (var p in View.Standings.Where(p => !p.IsSpectator))
        {
            <div class="f7standing @(p.Id == View.MyId ? "me" : "")">
                <span class="player-name">@p.Name</span>
                <span class="f7total">@p.Total</span>
                @if (p.Total >= Flip7Rules.WinningScore)
                {
                    <span class="badge ok" title="Past the target">@Flip7Rules.WinningScore+</span>
                }
            </div>
        }
    </div>

    @if (View.Phase is Flip7Phase.GameOver)
    {
        @if (View.HasHostPowers)
        {
            <button class="btn primary big" @onclick="() => Act(r => r.PlayAgain(View.MyId))">Play again</button>
            <div class="switch-games">
                <span class="switch-label">or switch the room to</span>
                @foreach (var g in GameInfo.All.Where(g => g.Type != GameType.Flip7))
                {
                    <button class="btn ghost" title="@g.Blurb" @onclick="() => OnSwitchGame(g.Type)">@g.Name</button>
                }
            </div>
        }
        else
        {
            <p class="hint">Waiting for @(View.HostName ?? "the host") to start another game…</p>
        }
    }
    else if (View.HasHostPowers)
    {
        <button class="btn primary big" @onclick="() => Act(r => r.NextRound(View.MyId))">
            @(View.WinnerId is not null ? "See the result" : "Next round")
        </button>
        @if (View.WinnerId is null && View.Standings.Any(p => p.Total >= Flip7Rules.WinningScore))
        {
            <p class="hint">
                @Tied players are level past @Flip7Rules.WinningScore, so everyone plays another round.
            </p>
        }
    }
    else
    {
        <p class="hint">Waiting for @(View.HostName ?? "the host") to deal the next round…</p>
    }

    <label class="confetti-toggle" title="Turn the celebration on or off for this browser">
        <input type="checkbox" checked="@(_prefRead && _confetti)" @onchange="ToggleConfetti" />
        <span>🎉 confetti</span>
    </label>
</div>

@code {
    [Parameter, EditorRequired] public required Flip7View View { get; set; }
    [Parameter, EditorRequired] public required Action<Action<Flip7Room>> Act { get; set; }

    /// <summary>Host switches the room to another game, keeping the code and players.</summary>
    [Parameter, EditorRequired] public required Action<GameType> OnSwitchGame { get; set; }

    private const string ConfettiPref = "party-confetti";

    private bool _confetti = true;
    private bool _prefRead;

    /// <summary>The two moments worth celebrating: a Flip 7, and winning the game.</summary>
    private bool Celebrate => View.Phase is Flip7Phase.GameOver || View.Flip7PlayerId is not null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // localStorage isn't there to read until the component is interactive, so the burst waits
        // for the preference (_prefRead) rather than flashing on for anyone who muted it.
        if (firstRender)
        {
            // A cosmetic preference must never take the room down with it: an old cached party.js
            // that predates getFlag would otherwise throw here and tear down the whole circuit.
            try
            {
                _confetti = await JS.InvokeAsync<bool>("party.getFlag", ConfettiPref, true);
            }
            catch (JSException)
            {
                _confetti = true;
            }

            _prefRead = true;
            StateHasChanged();
        }
    }

    private async Task ToggleConfetti(ChangeEventArgs e)
    {
        _confetti = e.Value is true;

        try
        {
            await JS.InvokeVoidAsync("party.setFlag", ConfettiPref, _confetti);
        }
        catch (JSException)
        {
            // The toggle still applies for this render; it just won't be remembered.
        }
    }

    private Flip7PlayerView? Winner => View.Players.FirstOrDefault(p => p.Id == View.WinnerId);

    /// <summary>How many are level at the top — any number of them can tie, not just two.</summary>
    private int Tied => View.Standings.Count(p => p.Total == View.Standings.Max(q => q.Total));

    private string Name(Guid id) => View.Players.FirstOrDefault(p => p.Id == id)?.Name ?? "Someone";
}
