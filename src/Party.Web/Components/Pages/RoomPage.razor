@page "/room/{Code}"
@implements IDisposable
@inject RoomManager Rooms
@inject IJSRuntime JS

@* The game-agnostic shell: find the room, work out who this is, then hand over to whichever
   game the room is playing. A code resolves to a room without anyone being asked which game
   they meant, which is the whole point of one code space. *@

@if (!_initialized)
{
    <div class="center-note">Connecting…</div>
}
else if (_roomMissing)
{
    <div class="home">
        <div class="home-card">
            <h2>Room not found</h2>
            <p>The room <strong>@Code.ToUpperInvariant()</strong> doesn't exist — it may have expired. Rooms close after an hour of inactivity.</p>
            <a class="btn primary" href="/">Start a new one</a>
        </div>
    </div>
}
else if (_needName)
{
    <div class="home">
        <div class="home-card">
            <h2>Joining @GameInfo.For(_handle!.Game).Name room @Code.ToUpperInvariant()</h2>
            <form @onsubmit="SubmitName">
                <label for="name">Your name</label>
                <input id="name" maxlength="@MaxNameLength" placeholder="e.g. Alex" @bind="_name" @bind:event="oninput" />
                @if (_error is not null)
                {
                    <div class="banner error">@_error</div>
                }
                <button class="btn primary big" type="submit">Join the game</button>
            </form>
        </div>
    </div>
}
@* Dispatch on the handle's own type rather than its game tag: the type test is what hands
   the stage a handle it definitely fits, so there is no cast here to get wrong. *@
else if (_handle is RoomHandle<GameRoom> justOne)
{
    <JustOneStage Handle="@justOne" PlayerId="@_playerId" PlayerName="@_name" />
}
else if (_handle is RoomHandle<Party.Flip7.Flip7Room> flip7)
{
    <Flip7Stage Handle="@flip7" PlayerId="@_playerId" PlayerName="@_name" />
}
else
{
    <div class="home">
        <div class="home-card">
            <h2>Can't open this room</h2>
            <p>The room <strong>@Code.ToUpperInvariant()</strong> is playing a game this page doesn't know how to show.</p>
            <a class="btn primary" href="/">Back to start</a>
        </div>
    </div>
}

@code {
    // The form is shared, so cap at whatever the strictest game allows rather than trusting
    // the two to stay in step.
    private static readonly int MaxNameLength =
        Math.Min(GameRoom.MaxNameLength, Party.Flip7.Flip7Room.MaxNameLength);

    [Parameter] public string Code { get; set; } = "";

    private RoomHandle? _handle;
    private Guid _playerId;
    private string _name = "";
    private bool _initialized;
    private bool _roomMissing;
    private bool _needName;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _playerId = Guid.Parse(await JS.InvokeAsync<string>("party.getOrCreatePlayerId"));
        _name = await JS.InvokeAsync<string>("party.getName");

        if (!Rooms.TryGetRoom(Code, out _handle))
        {
            _roomMissing = true;
        }
        else
        {
            // Follow the code across a game switch: when this handle is superseded, re-open on
            // whatever's now playing under the same code.
            _handle.Superseded += OnSuperseded;
            if (string.IsNullOrWhiteSpace(_name))
            {
                _needName = true;
            }
        }

        _initialized = true;
        StateHasChanged();
    }

    private void OnSuperseded() => _ = InvokeAsync(() =>
    {
        if (Rooms.TryGetRoom(Code, out var next) && !ReferenceEquals(next, _handle))
        {
            if (_handle is not null)
            {
                _handle.Superseded -= OnSuperseded;
            }

            _handle = next;
            _handle.Superseded += OnSuperseded;
            StateHasChanged();   // re-dispatch to the new game's stage
        }
    });

    public void Dispose()
    {
        if (_handle is not null)
        {
            _handle.Superseded -= OnSuperseded;
        }
    }

    private async Task SubmitName()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Enter a name first.";
            return;
        }

        _name = _name.Trim();
        await JS.InvokeVoidAsync("party.setName", _name);
        _error = null;
        _needName = false;
    }
}
