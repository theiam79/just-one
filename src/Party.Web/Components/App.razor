<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>💡</text></svg>" />
    <title>Party Games</title>
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    <script src="_framework/blazor.web.js"></script>
    <script src="@Assets["party.js"]"></script>
</body>

</html>

@code {
    // No prerendering: player identity comes from localStorage via JS interop,
    // so rendering before the circuit is interactive would only flash stale UI.
    private static readonly IComponentRenderMode PageRenderMode = new InteractiveServerRenderMode(prerender: false);
}
