@page "/room/{Code}"
@implements IDisposable
@inject RoomManager Rooms
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (!_initialized)
{
    <div class="center-note">Connecting…</div>
}
else if (_roomMissing)
{
    <div class="home">
        <div class="home-card">
            <h2>Room not found</h2>
            <p>The room <strong>@Code.ToUpperInvariant()</strong> doesn't exist — it may have expired. Rooms close after an hour of inactivity.</p>
            <a class="btn primary" href="/">Start a new one</a>
        </div>
    </div>
}
else if (_roomClosed)
{
    <div class="home">
        <div class="home-card">
            <h2>Room closed</h2>
            <p>This room was closed after an hour of inactivity.</p>
            <a class="btn primary" href="/">Back to start</a>
        </div>
    </div>
}
else if (_needName)
{
    <div class="home">
        <div class="home-card">
            <h2>Joining room @Code.ToUpperInvariant()</h2>
            <form @onsubmit="SubmitNameAndJoin">
                <label for="name">Your name</label>
                <input id="name" maxlength="@GameRoom.MaxNameLength" placeholder="e.g. Alex" @bind="_name" @bind:event="oninput" />
                @if (_error is not null)
                {
                    <div class="banner error">@_error</div>
                }
                <button class="btn primary big" type="submit">Join the game</button>
            </form>
        </div>
    </div>
}
else if (_view is null)
{
    <div class="center-note">Joining…</div>
}
else
{
    <div class="room">
        <header class="room-header">
            <a class="logo small" href="/">Just <span class="accent">One</span></a>
            <button class="room-code" title="Copy invite link" @onclick="CopyInvite">
                @_view.Code <span class="copy-hint">@(_copied ? "copied!" : "copy link")</span>
            </button>
        </header>

        @if (_error is not null)
        {
            <div class="banner error" @onclick="() => _error = null">@_error <span class="dismiss">✕</span></div>
        }

        <ScoreBar View="_view" />

        <section class="stage">
            @switch (_view.Phase)
            {
                case GamePhase.Lobby:
                    <LobbyPanel View="_view" Act="Act" />
                    break;
                case GamePhase.NumberPick:
                    <NumberPickPanel View="_view" Act="Act" />
                    break;
                case GamePhase.ClueWriting:
                    <CluePanel View="_view" Act="Act" />
                    break;
                case GamePhase.ClueReview:
                    <ReviewPanel View="_view" Act="Act" />
                    break;
                case GamePhase.Guessing:
                    <GuessPanel View="_view" Act="Act" />
                    break;
                case GamePhase.Judging:
                    <JudgePanel View="_view" Act="Act" />
                    break;
                case GamePhase.RoundResult:
                    <ResultPanel View="_view" Act="Act" />
                    break;
                case GamePhase.GameOver:
                    <GameOverPanel View="_view" Act="Act" />
                    break;
            }
        </section>

        @if (_view.HasHostPowers && !_view.IAmGuesser
             && _view.Phase is GamePhase.NumberPick or GamePhase.ClueWriting or GamePhase.ClueReview or GamePhase.Guessing or GamePhase.Judging)
        {
            <button class="btn ghost skip-round" title="If someone dropped off the call, abandon this round — it counts as a pass"
                    @onclick="() => Act(g => g.SkipRound(_view.MyId))">
                Skip this round (counts as a pass)
            </button>
        }

        <PlayerList View="_view" Act="Act" />
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private RoomHandle? _handle;
    private RoomView? _view;
    private Guid _playerId;
    private string _name = "";
    private bool _initialized;
    private bool _roomMissing;
    private bool _roomClosed;
    private bool _needName;
    private bool _joined;
    private bool _copied;
    private string? _error;
    private Action? _changedHandler;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _playerId = Guid.Parse(await JS.InvokeAsync<string>("justone.getOrCreatePlayerId"));
        _name = await JS.InvokeAsync<string>("justone.getName");

        if (!Rooms.TryGetRoom(Code, out _handle))
        {
            _roomMissing = true;
            _initialized = true;
            StateHasChanged();
            return;
        }

        _changedHandler = () => _ = InvokeAsync(OnRoomChanged);
        _handle.Changed += _changedHandler;
        _initialized = true;

        if (string.IsNullOrWhiteSpace(_name))
        {
            _needName = true;
        }
        else
        {
            Join();
        }

        StateHasChanged();
    }

    private async Task SubmitNameAndJoin()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Enter a name first.";
            return;
        }

        _name = _name.Trim();
        await JS.InvokeVoidAsync("justone.setName", _name);
        Join();
        if (_joined)
        {
            _needName = false;
        }
    }

    private void Join()
    {
        try
        {
            _handle!.Mutate(g =>
            {
                g.Join(_playerId, _name);
                g.PlayerConnected(_playerId);
            });
            _joined = true;
            _error = null;
            RefreshView();
        }
        catch (GameRuleException ex)
        {
            _error = ex.Message;
            _roomClosed = _handle!.IsClosed;
        }
    }

    /// <summary>Runs a game action for this player, surfacing rule violations as a banner.</summary>
    private void Act(Action<GameRoom> action)
    {
        if (_handle is null)
        {
            return;
        }

        try
        {
            _handle.Mutate(action);
            _error = null;
        }
        catch (GameRuleException ex)
        {
            _error = ex.Message;
        }

        RefreshView();
    }

    private void OnRoomChanged()
    {
        RefreshView();
        StateHasChanged();
    }

    private void RefreshView()
    {
        if (_handle is null)
        {
            return;
        }

        if (_handle.IsClosed)
        {
            _roomClosed = true;
            return;
        }

        if (_joined)
        {
            _view = _handle.Read(g => RoomView.Build(g, _playerId));
        }
    }

    private async Task CopyInvite()
    {
        var link = Nav.ToAbsoluteUri($"/room/{_view!.Code}").ToString();
        _copied = await JS.InvokeAsync<bool>("justone.copyText", link);
        if (_copied)
        {
            _ = ResetCopiedLater();
        }
    }

    private async Task ResetCopiedLater()
    {
        await Task.Delay(2000);
        _copied = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_handle is null)
        {
            return;
        }

        if (_changedHandler is not null)
        {
            _handle.Changed -= _changedHandler;
        }

        if (_joined && !_handle.IsClosed)
        {
            try
            {
                _handle.Mutate(g => g.PlayerDisconnected(_playerId));
            }
            catch
            {
                // The room may have been closed between the check and the call; nothing to clean up then.
            }
        }
    }
}
