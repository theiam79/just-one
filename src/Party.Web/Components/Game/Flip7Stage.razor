@using Party.Flip7
@inherits RoomStage<Flip7Room>

@if (RoomClosed)
{
    <RoomNotice Heading="Room closed" Detail="@ClosedDetail" />
}
@* Joining was refused — a full room, most likely. Say so, and offer a way out. *@
else if (_view is null && Error is not null)
{
    <RoomNotice Heading="Can't join this room" Detail="@Error" />
}
else if (_view is null)
{
    <div class="center-note">Joining…</div>
}
else
{
    <div class="room flip7">
        <RoomChrome Code="@_view.Code" CanClose="@_view.HasHostPowers" OnClose="CloseRoom">
            <Logo>Flip <span class="accent">7</span></Logo>
        </RoomChrome>

        @if (Error is not null)
        {
            <div class="banner error" @onclick="DismissError">@Error <span class="dismiss">✕</span></div>
        }

        @if (_view.Phase is not Flip7Phase.Lobby)
        {
            <div class="score-bar">
                <div class="stat"><span class="stat-value">@_view.RoundNumber</span><span class="stat-label">round</span></div>
                <div class="stat"><span class="stat-value">@(_view.Me?.Total ?? 0)</span><span class="stat-label">your points</span></div>
                @if (_view.Phase is not Flip7Phase.GameOver)
                {
                    <div class="stat"><span class="stat-value">@_view.DeckCount</span><span class="stat-label">cards left</span></div>
                }
            </div>
        }

        <section class="stage">
            @switch (_view.Phase)
            {
                case Flip7Phase.Lobby:
                    <Flip7LobbyPanel View="_view" Act="Act" />
                    break;
                case Flip7Phase.Dealing:
                case Flip7Phase.Turns:
                    <Flip7TurnPanel View="_view" Act="Act" />
                    break;
                case Flip7Phase.RoundResult:
                case Flip7Phase.GameOver:
                    <Flip7ResultPanel View="_view" Act="Act" />
                    break;
            }
        </section>

        @* Only while a round is live: the round's cards are set aside once it ends, so the
           table would be a row of empty seats. The standings carry the result instead. *@
        @if (_view.Phase is Flip7Phase.Dealing or Flip7Phase.Turns)
        {
            <Flip7Table View="_view" />
        }

        @* The round's play-by-play. Kept through the result phase so you can read back what
           happened; it clears when the next round is dealt. *@
        @if (_view.Phase is not Flip7Phase.Lobby)
        {
            <Flip7Log Entries="_view.Log" />
        }

        @* Every phase, not just the lobby: sitting out an away player is a mid-game control,
           and a mid-game joiner has to be able to see that they are watching. *@
        <PlayerList Seats="@_view.Roster" MyId="@_view.MyId" HasHostPowers="@_view.HasHostPowers"
                    OnBench="@(id => Act(r => r.BenchPlayer(_view.MyId, id)))">
            <Badges Context="seat">
                @{ var p = _view.Seat(seat.Id); }
                @if (p is not null && _view.Phase is not Flip7Phase.Lobby && !p.IsSpectator)
                {
                    @if (p.Id == _view.Flip7PlayerId)
                    {
                        <span class="badge ok" title="Seven different numbers">FLIP 7!</span>
                    }
                    else
                    {
                        @switch (p.Status)
                        {
                            case RoundStatus.Busted:
                                <span class="badge bad" title="Two of the same number">bust</span>
                                break;
                            case RoundStatus.Frozen:
                                <span class="badge soft" title="Frozen — points banked">frozen</span>
                                break;
                            case RoundStatus.Stayed:
                                <span class="badge soft" title="Stayed — points banked">stayed</span>
                                break;
                            case RoundStatus.Active when p.IsTheirTurn:
                                <span class="badge" title="It's their go">their go</span>
                                break;
                        }
                    }
                    @if (p.HasSecondChance)
                    {
                        <span class="badge soft" title="Holds a Second Chance — cancels one bust">♻</span>
                    }
                    <span class="f7total" title="Total this game">@p.Total</span>
                }
            </Badges>
        </PlayerList>
    </div>
}

@code {
    private Flip7View? _view;

    protected override void JoinRoom(Flip7Room room, Guid playerId, string name)
    {
        room.Join(playerId, name);
        room.PlayerConnected(playerId);
    }

    protected override void LeaveRoom(Flip7Room room, Guid playerId) => room.PlayerDisconnected(playerId);

    protected override void BuildView(RoomHandle<Flip7Room> handle, Guid playerId) =>
        _view = handle.Read(r => Flip7View.Build(r, playerId));

    protected override void ClearView() => _view = null;
}
