@page "/"
@inject RoomManager Rooms
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="home">
    <h1 class="logo">Just <span class="accent">One</span></h1>
    <p class="tagline">The cooperative word game — play together while you're on a call.</p>

    <div class="home-card">
        <label for="name">Your name</label>
        <input id="name" maxlength="@GameRoom.MaxNameLength" placeholder="e.g. Alex" @bind="_name" @bind:event="oninput" />

        @if (_error is not null)
        {
            <div class="banner error">@_error</div>
        }

        <button class="btn primary big" @onclick="CreateRoom">Create a room</button>

        <div class="divider"><span>or join a friend's room</span></div>

        <form class="join-row" @onsubmit="JoinRoom">
            <input class="code-input" maxlength="@RoomCode.Length" placeholder="CODE" @bind="_code" @bind:event="oninput" />
            <button class="btn" type="submit">Join</button>
        </form>
    </div>

    <p class="hint">Rooms are temporary — nothing is saved once everyone leaves.</p>
</div>

@code {
    private string _name = "";
    private string _code = "";
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _name = await JS.InvokeAsync<string>("party.getName");
        StateHasChanged();
    }

    private async Task CreateRoom()
    {
        if (!await ValidateName())
        {
            return;
        }

        var handle = Rooms.CreateRoom();
        Nav.NavigateTo($"/room/{handle.Code}");
    }

    private async Task JoinRoom()
    {
        if (!await ValidateName())
        {
            return;
        }

        if (!Rooms.TryGetRoom(_code, out var handle))
        {
            _error = "No room with that code — check it with your host.";
            return;
        }

        Nav.NavigateTo($"/room/{handle.Code}");
    }

    private async Task<bool> ValidateName()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Enter a name first.";
            return false;
        }

        _error = null;
        await JS.InvokeVoidAsync("party.setName", _name.Trim());
        return true;
    }
}
