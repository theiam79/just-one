@using Party.Core

@* This round's story, newest first — so the latest thing to happen is always in view without
   having to scroll, and the box can stay short. *@

<div class="f7log">
    <div class="f7log-head">Round log</div>
    @if (Entries.Count == 0)
    {
        <p class="f7empty">Nothing yet.</p>
    }
    else
    {
        <ol class="f7log-list">
            @foreach (var e in Entries.Reverse())
            {
                <li class="f7log-line @e.Category">@e.Text</li>
            }
        </ol>
    }
</div>

@code {
    [Parameter, EditorRequired] public required IReadOnlyList<GameLogEntry> Entries { get; set; }
}
