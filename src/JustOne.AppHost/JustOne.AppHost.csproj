<Project Sdk="Aspire.AppHost.Sdk/13.4.3">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <!-- The Aspire SDK injects its own pinned Aspire.Hosting.AppHost reference,
         which conflicts with central package management. -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../JustOne.Web/JustOne.Web.csproj" />
  </ItemGroup>
</Project>
