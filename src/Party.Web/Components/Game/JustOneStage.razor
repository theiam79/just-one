@inherits RoomStage<GameRoom>

@if (RoomClosed)
{
    <RoomNotice Heading="Room closed" Detail="@ClosedDetail" />
}
@* Joining was refused — a full room, most likely. Say so, and offer a way out. *@
else if (_view is null && Error is not null)
{
    <RoomNotice Heading="Can't join this room" Detail="@Error" />
}
else if (_view is null)
{
    <div class="center-note">Joining…</div>
}
else
{
    <div class="room">
        <RoomChrome Code="@_view.Code" CanClose="@_view.HasHostPowers" OnClose="CloseRoom">
            <Logo>Just <span class="accent">One</span></Logo>
        </RoomChrome>

        @if (Error is not null)
        {
            <div class="banner error" @onclick="DismissError">@Error <span class="dismiss">✕</span></div>
        }

        <ScoreBar View="_view" />

        <section class="stage">
            @switch (_view.Phase)
            {
                case GamePhase.Lobby:
                    <LobbyPanel View="_view" Act="Act" />
                    break;
                case GamePhase.NumberPick:
                    <NumberPickPanel View="_view" Act="Act" />
                    break;
                case GamePhase.ClueWriting:
                    <CluePanel View="_view" Act="Act" />
                    break;
                case GamePhase.ClueReview:
                    <ReviewPanel View="_view" Act="Act" />
                    break;
                case GamePhase.Guessing:
                    <GuessPanel View="_view" Act="Act" />
                    break;
                case GamePhase.Judging:
                    <JudgePanel View="_view" Act="Act" />
                    break;
                case GamePhase.RoundResult:
                    <ResultPanel View="_view" Act="Act" />
                    break;
                case GamePhase.GameOver:
                    <GameOverPanel View="_view" Act="Act" />
                    break;
            }
        </section>

        @if (_view.HasHostPowers && !_view.IAmGuesser
             && _view.Phase is GamePhase.NumberPick or GamePhase.ClueWriting or GamePhase.ClueReview or GamePhase.Guessing or GamePhase.Judging)
        {
            <button class="btn ghost skip-round" title="If someone dropped off the call, abandon this round — it counts as a pass"
                    @onclick="() => Act(g => g.SkipRound(_view.MyId))">
                Skip this round (counts as a pass)
            </button>
        }

        <PlayerList Seats="@_view.Roster" MyId="@_view.MyId" HasHostPowers="@_view.HasHostPowers"
                    OnBench="@(id => Act(g => g.BenchPlayer(_view.MyId, id)))">
            <Badges Context="seat">
                @{ var p = _view.Players.First(x => x.Id == seat.Id); }
                @if (p.IsGuesser)
                {
                    <span class="badge" title="Guesser this round">🎯</span>
                }
                @switch (p.ClueStatus)
                {
                    case ClueStatus.Done:
                        <span class="badge ok">✓ clue in</span>
                        break;
                    case ClueStatus.Writing:
                        <span class="badge soft">writing…</span>
                        @if (_view.HasHostPowers && p.Id != _view.MyId)
                        {
                            <button class="btn tiny" title="Skip their clue so the round can continue"
                                    @onclick="() => Act(g => g.SkipPlayerClue(_view.MyId, p.Id))">skip</button>
                        }
                        break;
                    case ClueStatus.Skipped:
                        <span class="badge soft">skipped</span>
                        break;
                }
            </Badges>
        </PlayerList>

        <RoomFeed Feed="Feed" MyId="PlayerId" OnSend="PostChat" />
    </div>
}

@code {
    private RoomView? _view;

    protected override void JoinRoom(GameRoom room, Guid playerId, string name)
    {
        room.Join(playerId, name);
        room.PlayerConnected(playerId);
    }

    protected override void LeaveRoom(GameRoom room, Guid playerId) => room.PlayerDisconnected(playerId);

    protected override void BuildView(RoomHandle<GameRoom> handle, Guid playerId) =>
        _view = handle.Read(g => RoomView.Build(g, playerId));

    protected override void ClearView() => _view = null;
}
